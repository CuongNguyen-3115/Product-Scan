# --- Hệ thống & OS ---
.DS_Store
desktop.ini
thumbs.db

# --- Backend (Flask/Python) ---
# Bỏ qua môi trường ảo (như .venv-ocr)
.venv*/
env/
venv/
ENV/

# Bỏ qua các file cache của Python
**/__pycache__/
*.py[cod]
*$py.class

# --- Frontend (Expo/React Native) ---
# Bỏ qua thư viện node
node_modules/

# Bỏ qua các folder lưu trữ tạm thời của Expo
.expo/
dist/
web-build/

# Bỏ qua các file log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- BẢO MẬT (QUAN TRỌNG) ---
# Bỏ qua tất cả các file .env ở cả Backend và Frontend
**/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local